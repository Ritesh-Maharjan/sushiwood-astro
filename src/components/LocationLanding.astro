---
import Popup from "@/_component/Popup";
import Footer from "@/components/Footer/Footer";
import HeroStatic from "@/components/Hero/HeroStatic.astro";
import LocationSelector from "@/components/LocationSelector.astro";
import OurPhilosophy from "@/components/OurPhilosophy.astro";
import RestaurantPhoto from "@/components/RestaurantPhoto.astro";
import MenuWrapper from "@/components/MenuWrapper.astro";
import TextMenu from "@/components/TextMenu.astro";
import type { LocationSlug } from "@/lib/locationData";

interface Props {
  location: LocationSlug;
}

const { location } = Astro.props;
---

<main class="flex flex-col gap-y-24">
  <!-- Popup wrapper is ~2KB (form code is lazy-loaded on open), so client:load is cheap and reliable -->
  <Popup client:load />

  <!-- Hero image is static HTML — LCP element is in the first byte -->
  <HeroStatic />

  <section id="location">
    <div class="flex items-center justify-center flex-col bg-white py-16">
      <div class="relative w-full text-center">
        <span class="h-0 absolute -z-10 left-0 top-1/2 w-full md:h-0.5 bg-white"></span>
        <h2
          class="pb-16 text-black text-3xl z-10 font-brandon-text uppercase tracking-wide w-40 md:w-fit md:px-8 mx-auto"
        >
          Select Location
        </h2>
      </div>
      <LocationSelector />
    </div>
  </section>

  <OurPhilosophy />
  <RestaurantPhoto />

  <!-- Menu images pre-optimized at build time, Swiper hydrates on scroll -->
  <MenuWrapper location={location} />

  <!-- Crawlable text version of the menu (search engines can't read the menu images) -->
  <TextMenu location={location} />
</main>

<Footer location={location} />
