---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout
  title="Blog | SushiWood"
  description="News, stories, and sushi culture from SushiWood — Japanese and Korean fusion restaurants in Fernie, Nelson, and Castlegar, BC."
  ogUrl="https://sushiwood.ca/blog"
>
  <div class="bg-white text-black min-h-[60vh]">
    <div class="mx-auto max-w-4xl p-6 pb-24">
      <h1 class="text-4xl font-bold text-center py-12 font-brandon-text uppercase tracking-wide">
        Blog
      </h1>
      <ul class="flex flex-col gap-8">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="group block border-b border-gray-200 pb-8">
              <p class="text-gray-500 text-sm mb-1">
                {post.data.date.toLocaleDateString("en-US", {
                  month: "long",
                  day: "numeric",
                  year: "numeric",
                })}
              </p>
              <h2 class="text-2xl font-semibold group-hover:underline">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-gray-600 mt-2">{post.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</Layout>
