---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const date = post.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "2-digit",
  year: "numeric",
});

const canonicalUrl = `https://sushiwood.ca/blog/${post.id}`;
// Fall back to the first ~155 chars of the post body when frontmatter has no description
const description =
  post.data.description ??
  post.body
    ?.replace(/!\[[^\]]*\]\([^)]*\)/g, "") // strip images
    .replace(/[#*_>\[\]]/g, "")
    .trim()
    .slice(0, 155);
const ogImage = post.data.image
  ? `https://sushiwood.ca${post.data.image}`
  : "https://sushiwood.ca/og-image.jpg";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description,
  image: ogImage,
  datePublished: post.data.date.toISOString(),
  url: canonicalUrl,
  author: { "@type": "Organization", name: "SushiWood" },
  publisher: { "@type": "Organization", name: "SushiWood", url: "https://sushiwood.ca/" },
};
---

<Layout
  title={`${post.data.title} | SushiWood Blog`}
  description={description}
  ogUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <div class="bg-white text-black">
    <article class="prose prose-lg mx-auto p-6 pb-24 max-w-7xl">
      <header class="pb-12">
        <p class="text-gray-500 text-xl text-right mb-6">{date}</p>
        <h1 class="text-4xl font-bold text-center">{post.data.title}</h1>
      </header>
      <main class="post-body flex flex-col gap-4">
        <Content />
      </main>
    </article>
  </div>
</Layout>

<style is:global>
  /* Match the markdown styling the Next.js page applied via react-markdown */
  .post-body h2 {
    font-size: 1.875rem;
    line-height: 2.25rem;
    font-weight: 700;
  }
  .post-body ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .post-body img {
    max-width: 100%;
  }
</style>
