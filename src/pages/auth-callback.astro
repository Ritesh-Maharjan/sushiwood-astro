---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Authenticating…">
  <div id="status">
    <h2>Redirecting...</h2>
  </div>
</Layout>

<script>
  // Hands the GitHub OAuth token back to the Decap CMS window that opened this popup
  const accessToken = new URLSearchParams(window.location.search).get("access_token");

  if (accessToken && window.opener) {
    window.opener.postMessage({ access_token: accessToken }, "*");
    window.close();
  } else {
    const status = document.getElementById("status")!;
    status.innerHTML =
      "<h2>Authentication Failed</h2><p>Could not complete authentication. Please try again.</p>";
  }
</script>
