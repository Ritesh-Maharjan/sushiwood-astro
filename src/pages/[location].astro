---
import Layout from "@/layouts/Layout.astro";
import LocationLanding from "@/components/LocationLanding.astro";
import { locationData, restaurantSchema, type LocationSlug } from "@/lib/locationData";

export function getStaticPaths() {
  return (Object.keys(locationData) as LocationSlug[]).map((location) => ({
    params: { location },
  }));
}

const location = Astro.params.location as LocationSlug;
const data = locationData[location];
const schema = restaurantSchema(location);
---

<Layout title={data.title} description={data.description} ogImage={data.image} ogUrl={data.url}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <LocationLanding location={location} />
</Layout>
