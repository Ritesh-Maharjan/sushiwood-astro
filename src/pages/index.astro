---
import Layout from "@/layouts/Layout.astro";
import LocationLanding from "@/components/LocationLanding.astro";
import { locationData, restaurantSchema } from "@/lib/locationData";

const fernie = locationData.fernie;
const schema = restaurantSchema("fernie");
---

<Layout
  title={fernie.title}
  description={fernie.description}
  ogImage={fernie.image}
  ogUrl={fernie.url}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <LocationLanding location="fernie" />
</Layout>
